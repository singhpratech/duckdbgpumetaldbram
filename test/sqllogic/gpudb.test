# name: test/sqllogic/gpudb.test
# description: gpudb loadable extension — gpu_sum / gpu_min / gpu_max (CPU-safe)
# group: [gpudb]
#
# This is the SQLLogicTest-format suite run by the community-extensions CI
# (extension-ci-tools duckdb_sqllogictest runner, pointed here via the root
# Makefile's TEST_RUNNER_BASE override). It is intentionally separate from the
# repo's custom-format test/sql/*.test suite (run by scripts/run_sql_tests.sh).
#
# All assertions are deterministic and backend-independent: integer sums/min/max
# on small inputs return identical results on the CPU, CUDA and Metal backends,
# so this passes in CI where no GPU is available.

# The functions do not exist until the extension is loaded.
statement error
SELECT gpu_sum(42::BIGINT);
----

# Loads gpudb (provided to the runner via --external-extension).
require gpudb

# Trivial range: 0+1+...+9 = 45
query I
SELECT gpu_sum(range::BIGINT) FROM range(10);
----
45

# Larger range: sum of 0..999999 = 499999500000
query I
SELECT gpu_sum(range::BIGINT) FROM range(1000000);
----
499999500000

# gpu_min / gpu_max over range(5, 15) = {5..14}
query I
SELECT gpu_min(range::BIGINT) FROM range(5, 15);
----
5

query I
SELECT gpu_max(range::BIGINT) FROM range(5, 15);
----
14

# Matches native SUM on an explicit value set.
query II
SELECT gpu_sum(v::BIGINT), sum(v::BIGINT)
FROM (VALUES (1), (2), (3), (10)) t(v);
----
16	16

# NULLs are ignored, like native aggregates.
query I
SELECT gpu_sum(v::BIGINT)
FROM (VALUES (1), (NULL), (3), (NULL), (6)) t(v);
----
10

# Empty input — SUM over zero rows is SQL NULL (v0.2.0), matching native SUM.
query I
SELECT gpu_sum(v::BIGINT) FROM (SELECT 1 AS v WHERE false) t;
----
NULL

# All-NULL input — SUM over zero non-NULL values is SQL NULL.
query I
SELECT gpu_sum(NULL::BIGINT);
----
NULL

# Mixed NULL + values — NULLs skipped, sum of the remainder.
query I
SELECT gpu_sum(v::BIGINT) FROM (VALUES (1), (2), (NULL)) t(v);
----
3

# GROUP BY with an all-NULL group — that group is NULL; others aggregate normally.
query II
SELECT k, gpu_sum(v) FROM (VALUES (1, NULL), (1, NULL), (2, 10)) t(k, v)
GROUP BY k ORDER BY k;
----
1	NULL
2	10

# MIN / MAX over empty input — SQL NULL.
query I
SELECT gpu_min(v::BIGINT) FROM (SELECT 1 AS v WHERE false) t;
----
NULL

query I
SELECT gpu_max(v::BIGINT) FROM (SELECT 1 AS v WHERE false) t;
----
NULL

# MIN / MAX over all-NULL input — SQL NULL.
query I
SELECT gpu_min(NULL::BIGINT);
----
NULL

query I
SELECT gpu_max(NULL::BIGINT);
----
NULL

# IS NULL is true for an empty / all-NULL aggregate (was false before v0.2.0).
query T
SELECT gpu_sum(NULL::BIGINT) IS NULL;
----
true

# ---------------------------------------------------------------------------
# Type widening (v0.2.0)
# ---------------------------------------------------------------------------

# Smaller integer types (INTEGER here) carry NO dedicated overload — they
# widen to the gpu_sum(BIGINT) overload via DuckDB's implicit integer cast, so
# the result type is BIGINT. 1 + 2 + 3 = 6.
query I
SELECT gpu_sum(v) FROM (VALUES (1::INTEGER), (2::INTEGER), (3::INTEGER)) t(v);
----
6

# ...and the widened result is BIGINT, not the input's INTEGER.
query T
SELECT typeof(gpu_sum(1::INTEGER));
----
BIGINT

# gpu_sum(DOUBLE) — the second, real overload. Returns DOUBLE. 1.5 + 2.25 =
# 3.75 (both exact in binary). On Apple Silicon the double sum runs on the host
# (Apple GPUs lack IEEE-754 doubles); the result is identical on every backend.
query R
SELECT gpu_sum(v) FROM (VALUES (1.5::DOUBLE), (2.25::DOUBLE)) t(v);
----
3.75

# All-NULL DOUBLE input — SUM over zero non-NULL values is SQL NULL.
query R
SELECT gpu_sum(NULL::DOUBLE);
----
NULL

# Empty DOUBLE input — SQL NULL via the output validity mask, matching native SUM.
query R
SELECT gpu_sum(v::DOUBLE) FROM (SELECT 1.0 AS v WHERE false) t;
----
NULL

# GROUP BY over DOUBLE — group 1 sums to 3.75; group 2 is all-NULL -> NULL.
query IR
SELECT k, gpu_sum(v) FROM (VALUES (1, 1.5::DOUBLE), (1, 2.25::DOUBLE), (2, NULL::DOUBLE)) t(k, v)
GROUP BY k ORDER BY k;
----
1	3.75
2	NULL
